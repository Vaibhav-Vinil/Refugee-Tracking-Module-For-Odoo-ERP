<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_refugee_skill_list" model="ir.ui.view">
        <field name="name">refugee.skill.list</field>
        <field name="model">refugee.skill</field>
        <field name="arch" type="xml">
            <list string="Skills">
                <field name="name"/>
                <field name="category"/>
            </list>
        </field>
    </record>
    <record id="view_refugee_skill_form" model="ir.ui.view">
        <field name="name">refugee.skill.form</field>
        <field name="model">refugee.skill</field>
        <field name="arch" type="xml">
            <form string="Skill">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="category"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_refugee_skill_search" model="ir.ui.view">
        <field name="name">refugee.skill.search</field>
        <field name="model">refugee.skill</field>
        <field name="arch" type="xml">
            <search string="Skills">
                <field name="name"/>
                <field name="category"/>
                <filter name="group_category" string="Category" context="{'group_by':'category'}"/>
            </search>
        </field>
    </record>

    <record id="action_refugee_skill" model="ir.actions.act_window">
        <field name="name">Skills</field>
        <field name="res_model">refugee.skill</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_refugee_skill_search"/>
    </record>
</odoo>
