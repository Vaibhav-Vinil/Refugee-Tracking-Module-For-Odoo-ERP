<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_refugee_profile_search" model="ir.ui.view">
        <field name="name">refugee.profile.search</field>
        <field name="model">refugee.profile</field>
        <field name="arch" type="xml">
            <search string="Refugees">
                <field name="name"/>
                <field name="refugee_id"/>
                <field name="family_name"/>
                <field name="camp_id"/>
                <field name="skill_ids"/>
                <field name="nationality_id"/>
                <separator/>
                <filter name="filter_urgent" string="Urgent care" domain="[('requires_urgent_care', '=', True)]"/>
                <filter name="filter_critical" string="Critical vulnerability" domain="[('vulnerability_level', '=', 'critical')]"/>
                <separator/>
                <filter name="filter_my_camp" string="My Camp" domain="[('is_my_camp_profile', '=', True)]"/>
                <separator/>
                <filter name="filter_draft" string="Draft" domain="[('journey_stage', '=', 'draft')]"/>
                <filter name="filter_assigned" string="Assigned" domain="[('journey_stage', '=', 'assigned')]"/>
                <group>
                    <filter name="group_camp" string="Camp" context="{'group_by': 'camp_id'}"/>
                    <filter name="group_nationality" string="Nationality" context="{'group_by': 'nationality_id'}"/>
                    <filter name="group_journey" string="Journey" context="{'group_by': 'journey_stage'}"/>
                    <filter name="group_vuln" string="Vulnerability" context="{'group_by': 'vulnerability_level'}"/>
                </group>
                <searchpanel>
                    <field name="camp_id" icon="fa-tent" enable_counters="1"/>
                    <field name="skill_ids" select="multi" icon="fa-tags" enable_counters="1"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="view_refugee_profile_list" model="ir.ui.view">
        <field name="name">refugee.profile.list</field>
        <field name="model">refugee.profile</field>
        <field name="arch" type="xml">
            <list string="Refugees">
                <field name="refugee_id"/>
                <field name="name"/>
                <field name="family_id"/>
                <field name="camp_id"/>
                <field name="vulnerability_level" decoration-danger="vulnerability_level == 'critical'"/>
                <field name="assigned_role_id"/>
                <field name="journey_stage" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_refugee_profile_form" model="ir.ui.view">
        <field name="name">refugee.profile.form</field>
        <field name="model">refugee.profile</field>
        <field name="arch" type="xml">
            <form string="Refugee Profile">
                <header>
                    <button name="action_auto_assign_roles" type="object" string="Auto Assign Roles" class="btn-primary"
                        groups="refugee_crisis_erp.group_refugee_manager"/>
                    <field name="journey_stage" widget="statusbar"
                        statusbar_visible="draft,vetting,medical,assigned,integrated"
                        groups="refugee_crisis_erp.group_refugee_manager,refugee_crisis_erp.group_refugee_volunteer"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_family_members" type="object" class="oe_stat_button" icon="fa-users"
                            invisible="not family_id"
                            groups="refugee_crisis_erp.group_refugee_manager,refugee_crisis_erp.group_refugee_volunteer">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Family</span>
                                <span class="o_stat_value"><field name="family_member_count"/></span>
                            </div>
                        </button>
                        <button name="action_open_aid" type="object" class="oe_stat_button" icon="fa-truck">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Aid</span>
                                <span class="o_stat_value"><field name="aid_count"/></span>
                            </div>
                        </button>

                    </div>
                    <field name="id_card_photo" widget="image" class="oe_avatar" options="{'preview_image': 'id_card_photo'}"
                        groups="refugee_crisis_erp.group_refugee_manager,refugee_crisis_erp.group_refugee_volunteer"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Full name"/></h1>
                        <h3><field name="refugee_id" readonly="1"/></h3>
                    </div>
                    <group>
                        <group string="Identification" groups="refugee_crisis_erp.group_refugee_manager,refugee_crisis_erp.group_refugee_volunteer">
                            <field name="fingerprint_hash" readonly="1"/>
                            <field name="id_number"/>
                        </group>
                        <group string="Camp" groups="refugee_crisis_erp.group_refugee_manager,refugee_crisis_erp.group_refugee_volunteer">
                            <field name="family_status" invisible="not family_id"/>
                            <field name="camp_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Personal" groups="refugee_crisis_erp.group_refugee_manager,refugee_crisis_erp.group_refugee_volunteer">
                            <group>
                                <field name="gender"/>
                                <field name="date_of_birth"/>
                                <field name="age" readonly="1"/>
                                <field name="nationality_id"/>
                                <field name="languages_spoken_ids" widget="many2many_tags"/>
                            </group>
                        </page>
                        <page string="Journey" groups="refugee_crisis_erp.group_refugee_manager,refugee_crisis_erp.group_refugee_volunteer">
                            <group>
                                <field name="journey_stage"/>
                            </group>
                        </page>
                        <page string="Vulnerability &amp; Health" groups="refugee_crisis_erp.group_refugee_manager,refugee_crisis_erp.group_refugee_volunteer">
                            <group>
                                <field name="vulnerability_level"/>
                                <field name="is_unaccompanied_minor"/>
                                <field name="medical_conditions"/>
                                <field name="requires_urgent_care"/>
                                <field name="health_status"/>
                                <field name="deceased"/>
                            </group>
                        </page>
                        <page string="Skills &amp; Role" groups="refugee_crisis_erp.group_refugee_manager,refugee_crisis_erp.group_refugee_volunteer">
                            <group>
                                <field name="skill_ids" widget="many2many_tags"/>
                                <field name="assigned_role_id"/>
                            </group>
                        </page>
                        <page string="Family" groups="refugee_crisis_erp.group_refugee_manager,refugee_crisis_erp.group_refugee_volunteer">
                            <group>
                                <field name="family_name"/>
                                <field name="family_id"/>
                                <field name="is_head_of_household"/>
                                <field name="is_head_of_family" widget="family_head_boolean"/>
                            </group>
                        </page>
                        <page string="Aid &amp; Distribution" groups="refugee_crisis_erp.group_refugee_manager,refugee_crisis_erp.group_refugee_volunteer">
                            <field name="aid_line_ids">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="resource_id"/>
                                    <field name="quantity"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter groups="refugee_crisis_erp.group_refugee_manager,refugee_crisis_erp.group_refugee_volunteer"/>
            </form>
        </field>
    </record>

    <record id="view_refugee_profile_kanban" model="ir.ui.view">
        <field name="name">refugee.profile.kanban</field>
        <field name="model">refugee.profile</field>
        <field name="arch" type="xml">
            <kanban default_group_by="journey_stage" class="o_kanban_small_column" create="1" quick_create="false"
                highlight_color="kanban_color">
                <field name="name"/>
                <field name="refugee_id"/>
                <field name="camp_id"/>
                <field name="vulnerability_level"/>
                <field name="skill_ids"/>
                <field name="assigned_role_id"/>
                <field name="kanban_color"/>
                <field name="id_card_photo"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="d-flex">
                                <div class="o_kanban_image me-2" style="width:64px;">
                                    <field name="id_card_photo" widget="image" options="{'size': [64, 64]}" alt="Photo"/>
                                </div>
                                <div class="oe_kanban_details flex-grow-1">
                                    <div class="fw-bold"><field name="name"/></div>
                                    <div class="text-muted small"><field name="refugee_id"/></div>
                                    <div t-if="record.camp_id.raw_value" class="small"><field name="camp_id"/></div>
                                    <span class="badge rounded-pill text-bg-danger" t-if="record.vulnerability_level.raw_value == 'critical'">Critical</span>
                                    <span class="badge rounded-pill text-bg-warning" t-elif="record.vulnerability_level.raw_value == 'high'">High</span>
                                    <div class="mt-1"><field name="skill_ids" widget="many2many_tags"/></div>
                                    <div t-if="record.assigned_role_id.raw_value" class="small mt-1">Role: <field name="assigned_role_id"/></div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_refugee_profile_graph" model="ir.ui.view">
        <field name="name">refugee.profile.graph</field>
        <field name="model">refugee.profile</field>
        <field name="arch" type="xml">
            <graph string="Refugees by nationality" type="bar">
                <field name="nationality_id"/>
            </graph>
        </field>
    </record>

    <record id="view_refugee_profile_pivot" model="ir.ui.view">
        <field name="name">refugee.profile.pivot</field>
        <field name="model">refugee.profile</field>
        <field name="arch" type="xml">
            <pivot string="Population analysis">
                <field name="nationality_id" type="row"/>
                <field name="vulnerability_level" type="col"/>
                <field name="age" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_refugee_profile" model="ir.actions.act_window">
        <field name="name">Refugees</field>
        <field name="res_model">refugee.profile</field>
        <field name="view_mode">kanban,list,form,graph,pivot</field>
        <field name="search_view_id" ref="view_refugee_profile_search"/>
        <field name="context">{'search_default_filter_my_camp': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Register a refugee profile to start the journey.</p>
        </field>
    </record>

    <record id="action_refugee_profile_graph" model="ir.actions.act_window">
        <field name="name">Population by nationality</field>
        <field name="res_model">refugee.profile</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_refugee_profile_graph"/>
    </record>

    <record id="action_refugee_profile_pivot" model="ir.actions.act_window">
        <field name="name">Age &amp; vulnerability pivot</field>
        <field name="res_model">refugee.profile</field>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="view_refugee_profile_pivot"/>
    </record>
</odoo>
