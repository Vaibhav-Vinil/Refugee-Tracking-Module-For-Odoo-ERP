<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_refugee_camp_list" model="ir.ui.view">
        <field name="name">refugee.camp.management.list</field>
        <field name="model">refugee.camp.management</field>
        <field name="arch" type="xml">
            <list string="Camps &amp; Shelters">
                <field name="name"/>
                <field name="parent_id" optional="show"/>
                <field name="total_capacity"/>
                <field name="current_occupancy"/>
                <field name="overcrowded_status" decoration-danger="overcrowded_status == 'overcrowded'"/>
                <field name="latitude" optional="hide"/>
                <field name="longitude" optional="hide"/>
            </list>
        </field>
    </record>
    <record id="view_refugee_camp_form" model="ir.ui.view">
        <field name="name">refugee.camp.management.form</field>
        <field name="model">refugee.camp.management</field>
        <field name="arch" type="xml">
            <form string="Camp / Shelter">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="parent_id"/>
                            <field name="location_label"/>
                        </group>
                        <group>
                            <field name="total_capacity"/>
                            <field name="current_occupancy"/>
                            <field name="overcrowded_status"/>
                            <field name="latitude"/>
                            <field name="longitude"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Refugees">
                            <field name="refugee_ids">
                                <list>
                                    <field name="refugee_id"/>
                                    <field name="name"/>
                                    <field name="vulnerability_level"/>
                                    <field name="journey_stage"/>
                                </list>
                            </field>
                        </page>
                        <page string="Resources">
                            <field name="resource_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="resource_type"/>
                                    <field name="quantity_available"/>
                                    <field name="stock_ratio" widget="progressbar"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_refugee_camp" model="ir.actions.act_window">
        <field name="name">Camps &amp; Shelters</field>
        <field name="res_model">refugee.camp.management</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
