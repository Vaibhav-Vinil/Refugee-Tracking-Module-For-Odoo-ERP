<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_refugee_resource_request_list" model="ir.ui.view">
        <field name="name">refugee.resource.request.list</field>
        <field name="model">refugee.resource.request</field>
        <field name="arch" type="xml">
            <list string="Resource Requests">
                <field name="name"/>
                <field name="camp_id" groups="refugee_crisis_erp.group_refugee_manager,refugee_crisis_erp.group_refugee_volunteer"/>
                <field name="resource_id"/>
                <field name="quantity"/>
                <field name="status" widget="badge" decoration-info="status == 'pending'" decoration-success="status == 'approved'" decoration-danger="status == 'denied'"/>
            </list>
        </field>
    </record>

    <record id="view_refugee_resource_request_form" model="ir.ui.view">
        <field name="name">refugee.resource.request.form</field>
        <field name="model">refugee.resource.request</field>
        <field name="arch" type="xml">
            <form string="Resource Request">
                <header>
                    <button name="action_approve" type="object" string="Approve" class="oe_highlight" invisible="status != 'pending'" groups="refugee_crisis_erp.group_refugee_volunteer,refugee_crisis_erp.group_refugee_manager"/>
                    <button name="action_deny" type="object" string="Deny" invisible="status != 'pending'" groups="refugee_crisis_erp.group_refugee_volunteer,refugee_crisis_erp.group_refugee_manager"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="camp_id" readonly="status != 'pending'" groups="refugee_crisis_erp.group_refugee_manager,refugee_crisis_erp.group_refugee_volunteer"/>
                            <field name="resource_id" readonly="status != 'pending'"/>
                        </group>
                        <group>
                            <field name="quantity" readonly="status != 'pending'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes" placeholder="Why is this resource needed?" readonly="status != 'pending'"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_refugee_resource_request" model="ir.actions.act_window">
        <field name="name">Resource Requests</field>
        <field name="res_model">refugee.resource.request</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
