<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_refugeeconnect" model="ir.ui.view">
        <field name="name">res.users.form.refugeeconnect</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="RefugeeConnect Profiles">
                    <group>
                        <field name="refugee_profile_id" context="{'default_name': name}"/>
                        <field name="volunteer_id" context="{'default_name': name}"/>
                    </group>
                </page>
            </notebook>
        </field>
    </record>
</odoo>
