<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_refugee_family_list" model="ir.ui.view">
        <field name="name">refugee.family.list</field>
        <field name="model">refugee.family</field>
        <field name="arch" type="xml">
            <list string="Families">
                <field name="name"/>
                <field name="member_count"/>
                <field name="head_id"/>
                <field name="camp_id"/>
                <field name="status"/>
                <field name="missing_member_hint" optional="hide"/>
            </list>
        </field>
    </record>
    <record id="view_refugee_family_form" model="ir.ui.view">
        <field name="name">refugee.family.form</field>
        <field name="model">refugee.family</field>
        <field name="arch" type="xml">
            <form string="Family">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="camp_id"/>
                        <field name="status"/>
                        <field name="head_id"/>
                    </group>
                    <field name="member_ids" mode="list,kanban">
                        <list>
                            <field name="refugee_id"/>
                            <field name="name"/>
                            <field name="journey_stage"/>
                            <field name="camp_id"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_refugee_family_kanban" model="ir.ui.view">
        <field name="name">refugee.family.kanban</field>
        <field name="model">refugee.family</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status" class="o_kanban_small_column">
                <field name="name"/>
                <field name="member_count"/>
                <field name="missing_member_hint"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="fw-bold"><field name="name"/></div>
                            <div>Members: <field name="member_count"/></div>
                            <div t-if="record.missing_member_hint.raw_value" class="text-danger small">
                                <field name="missing_member_hint"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="action_refugee_family" model="ir.actions.act_window">
        <field name="name">Families</field>
        <field name="res_model">refugee.family</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
</odoo>
