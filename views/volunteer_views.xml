<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_refugee_volunteer" model="ir.actions.act_window">
        <field name="name">Volunteers</field>
        <field name="res_model">refugee.volunteer</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_refugee_volunteer_list" model="ir.ui.view">
        <field name="name">refugee.volunteer.list</field>
        <field name="model">refugee.volunteer</field>
        <field name="arch" type="xml">
            <list string="Volunteers">
                <field name="name"/>
                <field name="group_id"/>
                <field name="phone"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_refugee_volunteer_form" model="ir.ui.view">
        <field name="name">refugee.volunteer.form</field>
        <field name="model">refugee.volunteer</field>
        <field name="arch" type="xml">
            <form string="Volunteer">
                <sheet>
                    <field name="photo" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="phone"/>
                            <field name="email"/>
                        </group>
                        <group>
                            <field name="group_id"/>
                            <field name="status"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Tasks">
                            <field name="task_ids" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_refugee_volunteer_group" model="ir.actions.act_window">
        <field name="name">Volunteer Groups</field>
        <field name="res_model">refugee.volunteer.group</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_refugee_volunteers" name="Volunteers" parent="menu_refugee_root" sequence="85"
        action="action_refugee_volunteer"
        groups="refugee_crisis_erp.group_refugee_manager,refugee_crisis_erp.group_refugee_field_worker"/>
        
    <menuitem id="menu_refugee_volunteer_groups" name="Volunteer Groups" parent="menu_refugee_root" sequence="86"
        action="action_refugee_volunteer_group"
        groups="refugee_crisis_erp.group_refugee_manager"/>
</odoo>
