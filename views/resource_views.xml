<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_refugee_resource_list" model="ir.ui.view">
        <field name="name">refugee.resource.inventory.list</field>
        <field name="model">refugee.resource.inventory</field>
        <field name="arch" type="xml">
            <list string="Resource Inventory">
                <field name="name"/>
                <field name="camp_id"/>
                <field name="resource_type"/>
                <field name="quantity_available" widget="progressbar" options="{'max_value': 'quantity_required'}"/>
                <field name="quantity_required"/>
                <field name="stock_ratio"/>
                <field name="expiry_date" optional="show"/>
            </list>
        </field>
    </record>
    <record id="view_refugee_resource_form" model="ir.ui.view">
        <field name="name">refugee.resource.inventory.form</field>
        <field name="model">refugee.resource.inventory</field>
        <field name="arch" type="xml">
            <form string="Resource">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="camp_id"/>
                        <field name="resource_type"/>
                        <field name="quantity_available" widget="progressbar" options="{'max_value': 'quantity_required'}"/>
                        <field name="quantity_required"/>
                        <field name="stock_ratio" readonly="1"/>
                        <field name="expiry_date"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_refugee_resource_search" model="ir.ui.view">
        <field name="name">refugee.resource.inventory.search</field>
        <field name="model">refugee.resource.inventory</field>
        <field name="arch" type="xml">
            <search string="Search Resources">
                <field name="name"/>
                <field name="camp_id"/>
                <field name="resource_type"/>
                <separator/>
                <filter string="Group by Camp" name="group_camp" context="{'group_by':'camp_id'}"/>
                <filter string="Group by Type" name="group_type" context="{'group_by':'resource_type'}"/>
            </search>
        </field>
    </record>

    <record id="action_refugee_resource" model="ir.actions.act_window">
        <field name="name">Resource Inventory</field>
        <field name="res_model">refugee.resource.inventory</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_refugee_resource_search"/>
    </record>
</odoo>
