<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_refugee_resource_list" model="ir.ui.view">
        <field name="name">refugee.resource.inventory.list</field>
        <field name="model">refugee.resource.inventory</field>
        <field name="arch" type="xml">
            <list string="Resource Inventory">
                <field name="name"/>
                <field name="camp_id"/>
                <field name="resource_type"/>
                <field name="quantity_available"/>
                <field name="stock_ratio" widget="progressbar"/>
                <field name="expiry_date" optional="show"/>
            </list>
        </field>
    </record>
    <record id="view_refugee_resource_form" model="ir.ui.view">
        <field name="name">refugee.resource.inventory.form</field>
        <field name="model">refugee.resource.inventory</field>
        <field name="arch" type="xml">
            <form string="Resource">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="camp_id"/>
                        <field name="resource_type"/>
                        <field name="quantity_available"/>
                        <field name="stock_ratio" widget="progressbar"/>
                        <field name="expiry_date"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_refugee_resource" model="ir.actions.act_window">
        <field name="name">Resource Inventory</field>
        <field name="res_model">refugee.resource.inventory</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
