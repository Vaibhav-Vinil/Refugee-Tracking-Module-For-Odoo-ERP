<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_refugee_logistics_list" model="ir.ui.view">
        <field name="name">refugee.logistics.task.list</field>
        <field name="model">refugee.logistics.task</field>
        <field name="arch" type="xml">
            <list string="Logistics Tasks">
                <field name="resource_id"/>
                <field name="camp_id"/>
                <field name="task_type"/>
                <field name="quantity"/>
                <field name="volunteer_ids" widget="many2many_tags"/>
                <field name="status" widget="badge"
                    decoration-info="status in ('todo', 'accepted')"
                    decoration-warning="status == 'authorized'"
                    decoration-success="status == 'done'"
                    decoration-danger="status in ('cancelled', 'stopped')"/>
                <button name="action_enroll" type="object" icon="fa-hand-paper-o" string="Enroll"
                    invisible="status in ('done', 'cancelled', 'stopped')"
                    groups="refugee_crisis_erp.group_refugee_volunteer"/>
                <button name="action_tick" type="object" icon="fa-check" string=" "
                    invisible="status in ('done', 'cancelled', 'stopped')"/>
                <button name="action_cross" type="object" icon="fa-times" string=" "
                    invisible="status in ('done', 'cancelled', 'stopped')"/>
                <field name="priority"/>
            </list>
        </field>
    </record>

    <record id="view_refugee_logistics_form" model="ir.ui.view">
        <field name="name">refugee.logistics.task.form</field>
        <field name="model">refugee.logistics.task</field>
        <field name="arch" type="xml">
            <form string="Logistics Task">
                <header>
                    <button name="action_enroll" type="object" string="Enroll Me" icon="fa-hand-paper-o"
                        invisible="status in ('done', 'cancelled', 'stopped')"
                        groups="refugee_crisis_erp.group_refugee_volunteer"/>
                    <button name="action_tick" type="object" string="Next Stage" icon="fa-check"
                        invisible="status in ('done', 'cancelled', 'stopped')" class="oe_highlight"/>
                    <button name="action_cross" type="object" string="Cancel/Stop" icon="fa-times"
                        invisible="status in ('done', 'cancelled', 'stopped')"/>
                    <field name="status" widget="statusbar" statusbar_visible="todo,accepted,authorized,in_progress,done"/>
                </header>
                <sheet>
                    <group>
                        <group string="Task Details">
                            <field name="resource_id"/>
                            <field name="camp_id"/>
                            <field name="task_type"/>
                            <field name="priority"/>
                            <field name="quantity"/>
                            <field name="date"/>
                        </group>
                        <group string="Delivery Info">
                            <field name="source_location"/>
                            <field name="destination"/>
                            <field name="refugee_id"/>
                            <field name="distributed_by_id"/>
                            <field name="request_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Assigned Volunteers">
                            <field name="volunteer_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="status"/>
                                    <field name="phone"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes" placeholder="Additional delivery notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_refugee_logistics_search" model="ir.ui.view">
        <field name="name">refugee.logistics.task.search</field>
        <field name="model">refugee.logistics.task</field>
        <field name="arch" type="xml">
            <search string="Logistics Tasks">
                <field name="resource_id"/>
                <field name="camp_id"/>
                <filter name="filter_todo" string="To Do" domain="[('status', '=', 'todo')]"/>
                <filter name="filter_accepted" string="Accepted" domain="[('status', '=', 'accepted')]"/>
                <filter name="filter_in_progress" string="In Progress" domain="[('status', '=', 'in_progress')]"/>
                <filter name="filter_done" string="Done" domain="[('status', '=', 'done')]"/>
                <separator/>
                <filter name="groupby_camp" string="Camp" context="{'group_by': 'camp_id'}"/>
                <filter name="groupby_status" string="Status" context="{'group_by': 'status'}"/>
                <filter name="groupby_type" string="Type" context="{'group_by': 'task_type'}"/>
            </search>
        </field>
    </record>

    <record id="action_refugee_logistics" model="ir.actions.act_window">
        <field name="name">Logistics Tasks</field>
        <field name="res_model">refugee.logistics.task</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_refugee_logistics_search"/>
    </record>
</odoo>
