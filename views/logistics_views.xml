<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_refugee_logistics_list" model="ir.ui.view">
        <field name="name">refugee.logistics.task.list</field>
        <field name="model">refugee.logistics.task</field>
        <field name="arch" type="xml">
            <list string="Logistics Tasks">
                <field name="name"/>
                <field name="task_type"/>
                <field name="assigned_to"/>
                <field name="status"/>
                <field name="priority"/>
            </list>
        </field>
    </record>
    <record id="view_refugee_logistics_form" model="ir.ui.view">
        <field name="name">refugee.logistics.task.form</field>
        <field name="model">refugee.logistics.task</field>
        <field name="arch" type="xml">
            <form string="Logistics Task">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="todo,in_progress,done"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="task_type"/>
                        <field name="assigned_to"/>
                        <field name="priority"/>
                        <field name="resource_id"/>
                        <field name="source_location"/>
                        <field name="destination"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_refugee_logistics_kanban" model="ir.ui.view">
        <field name="name">refugee.logistics.task.kanban</field>
        <field name="model">refugee.logistics.task</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status" class="o_kanban_small_column">
                <field name="name"/>
                <field name="task_type"/>
                <field name="assigned_to"/>
                <field name="priority"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="fw-bold"><field name="name"/></div>
                            <div class="text-muted small"><field name="task_type"/></div>
                            <div t-if="record.assigned_to.raw_value">Worker: <field name="assigned_to"/></div>
                            <div>Priority: <field name="priority"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="action_refugee_logistics" model="ir.actions.act_window">
        <field name="name">Logistics Tasks</field>
        <field name="res_model">refugee.logistics.task</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
</odoo>
